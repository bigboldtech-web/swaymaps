generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  passwordHash   String
  plan           String      @default("free")
  color          String?
  accounts       Account[]
  sessions       Session[]
  workspaces     Workspace[] @relation("WorkspaceOwner")
  memberships    WorkspaceMember[]
  maps           DecodeMap[] @relation("MapOwner")
  isAdmin        Boolean     @default(false)
  onboardedAt    DateTime?
  avatarUrl      String?
  subscriptions  Subscription[]
  templates      Template[]
  auditLogs      AuditLog[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Workspace {
  id        String             @id @default(cuid())
  name      String
  owner     User               @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  ownerId   String
  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  maps      DecodeMap[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  workspaceId String
  role        String

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id               String     @id @default(cuid())
  token            String     @unique
  email            String
  workspace        Workspace  @relation(fields: [workspaceId], references: [id])
  workspaceId      String
  role             String
  inviterUserId    String?
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Subscription {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id])
  userId           String
  plan             String
  status           String
  stripeCustomerId String?
  stripeSubId      String?
  stripePriceId     String?
  cancelAtPeriodEnd Boolean  @default(false)
  trialEnd          DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DecodeMap {
  id           String      @id @default(cuid())
  name         String
  description  String?
  isTemplate   Boolean     @default(false)
  publicShareId String?    @unique
  owner        User?       @relation("MapOwner", fields: [ownerId], references: [id])
  ownerId      String?
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id])
  workspaceId  String?
  nodes        MapNode[]
  edges        MapEdge[]
  notes        Note[]
  versions     MapVersion[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model MapNode {
  id        String    @id @default(cuid())
  map       DecodeMap @relation(fields: [mapId], references: [id])
  mapId     String
  kind      String
  kindLabel String
  title     String
  tags      String
  color     String
  note      Note?     @relation("NodeNote", fields: [noteId], references: [id])
  noteId    String?   @unique
  posX      Float
  posY      Float

  sourceEdges MapEdge[] @relation("SourceNode")
  targetEdges MapEdge[] @relation("TargetNode")
}

model MapEdge {
  id            String    @id @default(cuid())
  map           DecodeMap @relation(fields: [mapId], references: [id])
  mapId         String
  sourceNode    MapNode   @relation("SourceNode", fields: [sourceNodeId], references: [id])
  sourceNodeId  String
  sourceHandle  String?
  targetNode    MapNode   @relation("TargetNode", fields: [targetNodeId], references: [id])
  targetNodeId  String
  targetHandle  String?
  label         String?
  note          Note?     @relation("EdgeNote", fields: [noteId], references: [id])
  noteId        String?   @unique
}

model Note {
  id        String    @id @default(cuid())
  map       DecodeMap @relation(fields: [mapId], references: [id])
  mapId     String
  title     String
  tags      String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  node MapNode? @relation("NodeNote")
  edge MapEdge? @relation("EdgeNote")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  category    String
  thumbnail   String?
  mapData     String
  isPublic    Boolean  @default(true)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MapVersion {
  id        String    @id @default(cuid())
  mapId     String
  map       DecodeMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  String
  createdBy String?
  createdAt DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
